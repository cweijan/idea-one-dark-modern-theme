<idea-plugin>
     <id>github.cweijan.material-icons</id>
     <name>Material-icons</name>
     <vendor url="https://github.com/cweijan">cweijan</vendor>

     <description>
          <![CDATA[Material Icon Theme for JetBrains IDEs.<br>Replaces project view file and folder icons using the VSCode Material Icon Theme configuration.<br>Applies colorful icons to tool windows in the IDE sidebar.]]>
     </description>

     <depends>com.intellij.modules.platform</depends>

     <extensions defaultExtensionNs="com.intellij">
          <fileIconProvider implementation="github.cweijan.materialicons.MaterialFileIconProvider" order="first" />
          <projectViewNodeDecorator implementation="github.cweijan.materialicons.MaterialProjectViewDecorator"
               order="last" />
          <postStartupActivity
               implementation="github.cweijan.materialicons.toolwindow.ColorToolWindowIconPatcherActivity" />
     </extensions>

     <applicationListeners>
          <listener class="github.cweijan.materialicons.toolwindow.ColorToolWindowAppLifecycleListener"
               topic="com.intellij.ide.AppLifecycleListener" />
     </applicationListeners>

</idea-plugin>